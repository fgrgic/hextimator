{
	"name": "hextimator",
	"version": "0.0.1",
	"description": "color palette creator",
	"keywords": [
		"color",
		"palette",
		"generator",
		"creator",
		"oklch",
		"rgb",
		"rgb2oklch"
	],
	"homepage": "https://github.com/fgrgic/hextimator#readme",
	"bugs": {
		"url": "https://github.com/fgrgic/hextimator/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fgrgic/hextimator.git"
	},
	"license": "MIT",
	"bin": {
		"hextimator": "./dist/cli.mjs"
	},
	"author": "ditherbug",
	"main": "dist/index.js",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		},
		"./react": {
			"types": "./dist/react.d.ts",
			"import": "./dist/react.mjs",
			"require": "./dist/react.js"
		},
		"./tailwind.css": "./tailwind.css"
	},
	"files": [
		"dist",
		"tailwind.css"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "bun test"
	},
	"peerDependencies": {
		"react": ">=18"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/react": "^19.2.7",
		"react": "^19.2.0",
		"tsup": "^8.0.0",
		"typescript": "^5.0.0"
	}
}
